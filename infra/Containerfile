FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y \
    openssh-server \
    sudo \
    python3 \
    python3-pip \
    vim \
    iputils-ping \
    net-tools && \
    rm -rf /var/lib/apt/lists/*

RUN useradd -m -s /bin/bash redis

RUN echo "redis ALL=(ALL) NOPASSWD:ALL" >> /etc/sudoers

RUN mkdir /var/run/sshd

RUN mkdir -p /home/redis/.ssh && \
    chmod 700 /home/redis/.ssh && \
    chown -R redis:redis /home/redis/.ssh

# --- Bake the host's SSH public key into the image ---
# Expects infra/id_rsa.pub to exist in the build context (see README setup).
COPY --chown=redis:redis id_rsa.pub /home/redis/.ssh/authorized_keys
RUN chmod 600 /home/redis/.ssh/authorized_keys

EXPOSE 22

CMD ["/usr/sbin/sshd", "-D"]
